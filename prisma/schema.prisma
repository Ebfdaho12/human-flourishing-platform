generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Switch to "postgresql" and set DATABASE_URL to your Postgres connection string for production.
  // Local dev: DATABASE_URL="file:./prisma/dev.db"  (SQLite, default)
  // Production: DATABASE_URL="postgresql://user:pass@host:5432/hfp?sslmode=require"
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity ─────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified DateTime?
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  didIdentifier String?  @unique
  merkleRoot    String?
  publicKeyHint String?

  profile        UserProfile?
  claims         IdentityClaim[]
  wallet         Wallet?
  moduleActivity ModuleActivity[]
  moduleInterest ModuleInterest[]
  healthEntries  HealthEntry[]
  healthGoals    HealthGoal[]
  aiInsights     AIInsight[]
  moodEntries    MoodEntry[]
  journalEntries JournalEntry[]
  learningGoals  LearningGoal[]
  lessonSessions LessonSession[]
  govRecords     GovRecord[]
  researchStudies ResearchStudy[]
  replications   Replication[]
  peerReviews    PeerReview[]
  econInterventions EconIntervention[]
  infraProjects  InfraProject[]
  energyLogs     EnergyLog[]
  healthCases    HealthCase[]
  caseProposals  CaseProposal[]

  auditLogs          AuditLog[]

  // Social & messaging
  sentMessages       DirectMessage[]       @relation("SentMessages")
  receivedMessages   DirectMessage[]       @relation("ReceivedMessages")
  accountabilityAs   AccountabilityPartner[] @relation("AccountabilityUser")
  accountabilityWith AccountabilityPartner[] @relation("AccountabilityPartner")
  familyMemberships  FamilyMember[]
  familyMessages     FamilyMessage[]       @relation("FamilyMessages")
  discussionPosts    DiscussionPost[]      @relation("DiscussionPosts")
  cohortMemberships  CohortMember[]
  cohortMessages     CohortMessage[]       @relation("CohortMessages")
  insights           Insight[]             @relation("Insights")

  @@index([email])
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?
  avatarUrl   String?
  bio         String?
  location    String?
  timezone    String?

  profileVisibility  String  @default("PRIVATE")
  shareHealthData    Boolean @default(false)
  shareEduProgress   Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IdentityClaim {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  claimType      String
  leafIndex      Int
  encryptedValue String
  displayLabel   String
  isVerified     Boolean  @default(false)
  verifiedBy     String?
  verifiedAt     DateTime?
  expiresAt      DateTime?
  valueHash      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, claimType])
  @@index([userId, claimType])
}

// ─── Token Economy ────────────────────────────────────────────────────────────

model Wallet {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  foundBalance  BigInt @default(0)
  voiceBalance  BigInt @default(0)
  stakedFound   BigInt @default(0)
  stakeStartedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions  Transaction[]
  stakingEvents StakingEvent[]
}

model Transaction {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  tokenType    String
  amount       BigInt
  balanceAfter BigInt
  txType       String
  description  String
  referenceId  String?
  moduleId     String?
  onChainTxHash String?

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([walletId, tokenType])
}

model StakingEvent {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  eventType String
  amount    BigInt
  createdAt DateTime @default(now())

  @@index([walletId])
}

// ─── Module Activity ──────────────────────────────────────────────────────────

model ModuleActivity {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId     String
  activityKey  String
  metadata     String?
  foundAwarded BigInt   @default(0)
  createdAt    DateTime @default(now())

  @@unique([userId, moduleId, activityKey])
  @@index([userId, moduleId])
}

model ModuleInterest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String
  createdAt DateTime @default(now())

  @@unique([userId, moduleId])
}

// ─── Health Intelligence ──────────────────────────────────────────────────────

model HealthEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // VITALS | SYMPTOM | EXERCISE | SLEEP | NUTRITION | MEDICATION | MEASUREMENT
  entryType  String
  data       String   // JSON blob — flexible per type
  notes      String?
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, entryType])
  @@index([userId, recordedAt])
}

model HealthGoal {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // STEPS | WEIGHT | SLEEP_HOURS | WATER_L | EXERCISE_MIN | BLOOD_PRESSURE | CUSTOM
  goalType    String
  title       String
  target      String    // JSON — {value, unit}
  current     String?   // JSON — latest logged value
  deadline    DateTime?
  isActive    Boolean   @default(true)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, isActive])
}

// ─── AI Insights (shared across modules) ─────────────────────────────────────

model AIInsight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // HEALTH | MENTAL_HEALTH | EDUCATION
  moduleId    String
  // TREND | RECOMMENDATION | ALERT | SUMMARY | ENCOURAGEMENT
  insightType String
  content     String
  dataContext String?  // brief description of what data was analyzed
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, moduleId, isRead])
}

// ─── Mental Health & Community ────────────────────────────────────────────────

model MoodEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  score      Int      // 1-10
  emotions   String   // JSON string[]
  notes      String?
  triggers   String?  // JSON string[]
  activities String?  // JSON string[]
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, recordedAt])
}

model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String?
  content     String
  mood        Int?     // optional mood score at writing time
  tags        String?  // JSON string[]
  isEncrypted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
}

// ─── Education Intelligence ───────────────────────────────────────────────────

model LearningGoal {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject     String
  topic       String
  level       String    @default("BEGINNER")  // BEGINNER | INTERMEDIATE | ADVANCED
  description String?
  targetDate  DateTime?
  isActive    Boolean   @default(true)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  sessions    LessonSession[]

  @@index([userId, isActive])
}

model LessonSession {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId    String?
  goal      LearningGoal? @relation(fields: [goalId], references: [id])

  subject   String
  topic     String
  level     String        @default("BEGINNER")
  messages  String        // JSON {role:"user"|"assistant", content:string}[]
  durationS Int           @default(0)  // seconds
  score     Int?          // mastery score 0-100
  createdAt DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([goalId])
}

// ─── Governance Transparency ──────────────────────────────────────────────────

model GovRecord {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // POLITICIAN | VOTE | LEGISLATION | CIVIC_ACTION
  entityType   String
  title        String
  jurisdiction String?
  party        String?
  office       String?
  data         String   // JSON — flexible per entityType
  sourceUrl    String?
  notes        String?
  aiAnalysis   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, entityType])
  @@index([userId, createdAt])
}

// ─── DeSci Platform ───────────────────────────────────────────────────────────

model ResearchStudy {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title        String
  field        String   // biology | physics | psychology | economics | etc.
  hypothesis   String
  methodology  String
  // PRE_REGISTERED | IN_PROGRESS | COMPLETED | PEER_REVIEWED
  status       String   @default("PRE_REGISTERED")
  results      String?
  dataUrl      String?
  isPublic     Boolean  @default(true)
  aiReview     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  replications Replication[]
  reviews      PeerReview[]

  @@index([userId])
  @@index([status, isPublic])
}

model Replication {
  id        String        @id @default(cuid())
  studyId   String
  study     ResearchStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CONFIRMED | REFUTED | INCONCLUSIVE
  outcome   String
  notes     String?
  createdAt DateTime @default(now())

  @@index([studyId])
  @@index([userId])
}

model PeerReview {
  id        String        @id @default(cuid())
  studyId   String
  study     ResearchStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  quality   Int      // 1-5 methodology quality
  rigor     Int      // 1-5 statistical rigor
  comments  String
  createdAt DateTime @default(now())

  @@unique([studyId, userId])
  @@index([studyId])
}

// ─── Economic Blueprint ───────────────────────────────────────────────────────

model EconIntervention {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  // HEALTH | EDUCATION | NUTRITION | ENERGY | INFRASTRUCTURE | GOVERNANCE | OTHER
  category      String
  region        String
  costUSD       Float
  description   String
  // LOW | MEDIUM | HIGH | VERY_HIGH
  evidenceLevel String   @default("MEDIUM")
  roiScore      Int?     // 0-100, AI-generated Copenhagen Consensus style
  timelineYears Int?
  beneficiaries Int?
  aiAnalysis    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([category, roiScore])
}

// ─── Infrastructure Intelligence ─────────────────────────────────────────────

model InfraProject {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  // ROAD | BRIDGE | BUILDING | WATER | ENERGY | DIGITAL | SANITATION | OTHER
  projectType   String
  location      String
  climateZone   String?
  // PLANNED | IN_PROGRESS | COMPLETED | MAINTENANCE
  status        String   @default("PLANNED")
  budgetUSD     Float?
  lifespanYears Int?
  // MINIMUM | STANDARD | PREMIUM
  qualityTier   String   @default("STANDARD")
  specs         String?  // JSON
  tcoCostUSD    Float?   // Total cost of ownership (AI calculated)
  tcoSavingsUSD Float?   // Savings vs minimum-spec alternative
  aiAnalysis    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([projectType, status])
}

// ─── Decentralized Energy Grid ────────────────────────────────────────────────

model EnergyLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PRODUCTION | CONSUMPTION | STORAGE_CHARGE | STORAGE_DISCHARGE
  logType      String
  // SOLAR | WIND | HYDRO | BATTERY | GRID | GENERATOR | OTHER
  sourceType   String
  amountKwh    Float
  pricePerKwh  Float?
  co2SavedKg   Float?
  peakDemand   Boolean  @default(false)
  notes        String?
  recordedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId, logType])
  @@index([userId, recordedAt])
}

// ─── Anonymous Health Cases (ZK-Protected) ──────────────────────────────────
// Patients share anonymized health data. Practitioners propose treatments.
// Identity is ZK-proven (real user) but NEVER revealed until patient consents.

model HealthCase {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Anonymous identifier — NOT the user's real ID
  anonId        String   @unique @default(cuid())

  title         String   // "Chronic fatigue with unexplained weight gain"
  // CARDIOLOGY | NEUROLOGY | DERMATOLOGY | ENDOCRINOLOGY | GASTRO |
  // ORTHOPEDIC | PULMONARY | PSYCHIATRY | GENERAL | OTHER
  specialty     String
  // Brief, de-identified symptom summary
  symptoms      String
  // Duration, onset, progression
  timeline      String?
  // Relevant health data the patient chooses to share (JSON)
  sharedData    String?
  // What the patient has already tried
  priorTreatment String?
  // What they're looking for
  seekingHelp   String?

  // OPEN | IN_REVIEW | MATCHED | CLOSED
  status        String   @default("OPEN")
  // Age range (not exact), sex, relevant demographics — all optional
  demographics  String?  // JSON {ageRange, sex, relevantHistory}

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  proposals     CaseProposal[]

  @@index([specialty, status])
  @@index([userId])
}

model CaseProposal {
  id              String   @id @default(cuid())
  caseId          String
  case            HealthCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  practitionerId  String
  practitioner    User     @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  // Practitioner's credentials and specialty
  credentials     String   // "Board-certified endocrinologist, 12 years experience"
  // Their analysis of the case
  analysis        String
  // Proposed treatment approach with reasoning
  proposedTreatment String
  // Evidence/research backing the proposal
  evidence        String?
  // Root cause theory
  rootCauseTheory String?

  // PENDING | VIEWED | ACCEPTED | DECLINED
  status          String   @default("PENDING")
  // If accepted, patient can reveal contact
  contactRevealed Boolean  @default(false)
  // Encrypted contact info — only decryptable by the practitioner who was accepted
  encryptedContact String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([caseId])
  @@index([practitionerId])
  @@unique([caseId, practitionerId])
}

// ─── Audit Logging ────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  metadata   String?
  ip         String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([resource])
}

// ─── Email Verification ───────────────────────────────────────────────────────

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── Social & Messaging ──────────────────────────────────────────────────────

// Direct messages between users (encrypted)
model DirectMessage {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String   // encrypted with recipient's public key
  encrypted   Boolean  @default(true)
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([receiverId, read])
}

// Accountability partner pairings
model AccountabilityPartner {
  id          String   @id @default(cuid())
  userId      String
  partnerId   String
  goal        String   // what they're working on together
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, ENDED
  checkInDay  String   @default("MONDAY") // day of weekly check-in
  startedAt   DateTime @default(now())
  endedAt     DateTime?

  user        User     @relation("AccountabilityUser", fields: [userId], references: [id])
  partner     User     @relation("AccountabilityPartner", fields: [partnerId], references: [id])
  checkIns    PartnerCheckIn[]

  @@unique([userId, partnerId])
  @@index([userId])
  @@index([partnerId])
}

model PartnerCheckIn {
  id            String   @id @default(cuid())
  partnershipId String
  userId        String   // who is checking in
  progress      String   // what they accomplished
  blockers      String?  // what's in the way
  nextWeekGoal  String?  // what they'll do next
  rating        Int      @default(5) // 1-10 how the week went
  createdAt     DateTime @default(now())

  partnership   AccountabilityPartner @relation(fields: [partnershipId], references: [id], onDelete: Cascade)

  @@index([partnershipId])
}

// Family groups (private spaces)
model FamilyGroup {
  id          String   @id @default(cuid())
  name        String
  createdBy   String
  inviteCode  String   @unique @default(cuid())
  createdAt   DateTime @default(now())

  members     FamilyMember[]
  messages    FamilyMessage[]

  @@index([inviteCode])
}

model FamilyMember {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  role        String   @default("MEMBER") // ADMIN, MEMBER
  joinedAt    DateTime @default(now())

  group       FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
}

model FamilyMessage {
  id          String   @id @default(cuid())
  groupId     String
  senderId    String
  content     String
  type        String   @default("TEXT") // TEXT, INSIGHT, CHECKIN, MILESTONE
  metadata    String?  // JSON: tool link, achievement data, etc.
  createdAt   DateTime @default(now())

  group       FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender      User        @relation("FamilyMessages", fields: [senderId], references: [id])

  @@index([groupId])
  @@index([groupId, createdAt])
}

// Topic discussion rooms
model DiscussionRoom {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  category    String   // FINANCE, FAMILY, HEALTH, CANADA, EDUCATION, GENERAL
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  posts       DiscussionPost[]

  @@index([slug])
  @@index([category])
}

model DiscussionPost {
  id          String   @id @default(cuid())
  roomId      String
  authorId    String
  content     String
  type        String   @default("DISCUSSION") // DISCUSSION, INSIGHT, QUESTION, RESOURCE
  toolLink    String?  // link to a platform tool that inspired this post
  sourceUrl   String?  // evidence/source link
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)
  replyCount  Int      @default(0)
  parentId    String?  // for threaded replies
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  room        DiscussionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author      User           @relation("DiscussionPosts", fields: [authorId], references: [id])
  votes       PostVote[]
  replies     DiscussionPost[] @relation("PostReplies")
  parent      DiscussionPost?  @relation("PostReplies", fields: [parentId], references: [id])

  @@index([roomId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model PostVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  value     Int      // +1 or -1
  createdAt DateTime @default(now())

  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

// Community challenge cohorts
model ChallengeCohort {
  id            String   @id @default(cuid())
  challengeId   String   // "health-30", "mindset-30", "finance-30"
  name          String   // "January 2026 Health Kickstart"
  startDate     DateTime
  maxMembers    Int      @default(50)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  members       CohortMember[]
  messages      CohortMessage[]

  @@index([challengeId])
  @@index([startDate])
}

model CohortMember {
  id          String   @id @default(cuid())
  cohortId    String
  userId      String
  progress    Int      @default(0) // days completed
  joinedAt    DateTime @default(now())

  cohort      ChallengeCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])

  @@unique([cohortId, userId])
  @@index([userId])
}

model CohortMessage {
  id          String   @id @default(cuid())
  cohortId    String
  senderId    String
  content     String
  type        String   @default("CHAT") // CHAT, CHECKIN, MILESTONE, ENCOURAGEMENT
  day         Int?     // which challenge day this relates to
  createdAt   DateTime @default(now())

  cohort      ChallengeCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  sender      User            @relation("CohortMessages", fields: [senderId], references: [id])

  @@index([cohortId, createdAt])
}

// User insights (public sharing — not a feed, topic-sorted)
model Insight {
  id          String   @id @default(cuid())
  authorId    String
  content     String   // the insight text (min 50 chars, max 500)
  toolLink    String?  // which platform tool inspired this
  topicTag    String   // FINANCE, FAMILY, HEALTH, CANADA, EDUCATION, GROWTH
  sourceUrl   String?  // evidence link (optional but encouraged)
  upvotes     Int      @default(0)
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())

  author      User     @relation("Insights", fields: [authorId], references: [id])
  votes       InsightVote[]

  @@index([topicTag, createdAt])
  @@index([authorId])
}

model InsightVote {
  id        String   @id @default(cuid())
  insightId String
  userId    String
  value     Int      // +1 helpful, -1 not helpful
  createdAt DateTime @default(now())

  insight   Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)

  @@unique([insightId, userId])
}

